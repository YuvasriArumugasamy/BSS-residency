# Copy this file to .env and fill in real values. Do NOT commit .env.

# MongoDB Atlas connection string.
# Example: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/bss_residency?retryWrites=true&w=majority
MONGO_URI=

# Port for local development. Render sets PORT automatically — leave as 5000 locally.
PORT=5000

# Frontend origin(s) allowed by CORS. Comma-separated list.
# Local dev:   http://localhost:3000
# Production:  https://bss-residency.vercel.app
# Both:        http://localhost:3000,https://bss-residency.vercel.app
FRONTEND_URL=http://localhost:3000

# Admin panel credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bss@2025

# Email Notification Configuration (Gmail SMTP)
# Step 1: Enable 2-Factor Authentication on your Gmail account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Generate an "App Password" and paste it below
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=admin-email@gmail.com
