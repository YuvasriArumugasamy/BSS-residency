# Copy this file to .env and fill in real values. Do NOT commit .env.

# Base URL of the deployed backend API.
# Local dev:   leave empty (CRA proxy handles forwarding to http://localhost:5000)
# Production:  https://bss-residency.onrender.com
REACT_APP_API_URL=

# URL of the live website (used for "View Site" button in Admin Dashboard)
# Local dev:   leave empty (defaults to /)
# Production:  https://your-site.vercel.app
REACT_APP_SITE_URL=

# Web Push VAPID public key (Firebase Console → Project settings → Cloud Messaging → Web Push certificates)
REACT_APP_FIREBASE_VAPID_KEY=
